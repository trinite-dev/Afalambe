{
  "name": "@afalambe/afalambe",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@afalambe/web",
    "dev:api": "turbo run dev --filter=@afalambe/api",
    "dev:all": "turbo run dev --filter=@afalambe/web --filter=@afalambe/api",
    "lint": "turbo run lint",
    "lint:fix": "pnpm format && pnpm lint",
    "format": "prettier --write .",
    "test": "turbo run test",
    "test:unit": "turbo run test --filter=@afalambe/ai --filter=@afalambe/emails --filter=@afalambe/prisma --filter=@afalambe/testing --filter=@afalambe/trpc --filter=@afalambe/ui",
    "test:integration": "turbo run test --filter=@afalambe/api --filter=@afalambe/web",
    "test:e2e": "playwright test",
    "test:ui": "vitest --ui",
    "tdd": "vitest watch",
    "test-playwright": "playwright test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean --parallel",
    "prisma": "pnpm --filter @afalambe/prisma run prisma",
    "db:studio": "pnpm --filter @afalambe/prisma run db:studio",
    "env-check:web": "dotenv-checker --schema apps/web/.env.example --env apps/web/.env.example",
    "env-check:api": "dotenv-checker --schema apps/api/.env.example --env apps/api/.env.example",
    "env-check:emails": "dotenv-checker --schema packages/emails/.env.example --env packages/emails/.env.example",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node -e \"console.log('release is disabled: private/internal monorepo')\""
  },
  "devDependencies": {
    "@changesets/cli": "latest",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/ui": "^4.1.3",
    "dotenv-checker": "^1.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "turbo": "latest",
    "vitest": "^4.1.3"
  }
}
